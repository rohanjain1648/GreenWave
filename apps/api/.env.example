# GreenWave API — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# xAI Grok API key — get one at https://console.x.ai
# Required for the /api/insights endpoint.
GROK_API_KEY=your_xai_api_key_here

# Optional: override the Grok model (default: grok-3-latest)
# Options: grok-3-latest, grok-3-mini-latest, grok-2-1212
# GROK_MODEL=grok-3-latest

# Optional: override the port (Render sets this automatically)
# PORT=8000
