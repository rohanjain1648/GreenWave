# GreenWave API — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Groq API key — get one at https://console.groq.com
# Required for the /api/insights endpoint.
GROQ_API_KEY=your_groq_api_key_here

# Optional: override the Groq model (default: llama-3.1-70b-versatile)
# Options: llama-3.1-70b-versatile, llama-3.1-8b-instant, gemma-7b-it
# GROQ_MODEL=llama-3.1-70b-versatile

# Optional: override the port (Render sets this automatically)
# PORT=8000
